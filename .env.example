# Runtime: OFF | SHADOW | PAPER | LIVE
TRADING_MODE=OFF
LIVE_ARMED=false
APP_ENV=development
APP_TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO

# API and application
API_HOST=0.0.0.0
API_PORT=8000
APP_JWT_SECRET=replace-through-secret-manager

# Database / Redis
DATABASE_URL=postgresql+asyncpg://trader:change-me@postgres:5432/trader
REDIS_URL=redis://:change-me@redis:6379/0

# Kite — supply from Secret Manager in deployed environment
KITE_API_KEY=your-api-key
KITE_API_SECRET=your-api-secret
KITE_REDIRECT_URL=http://localhost:8000/auth/kite/callback
KITE_ACCESS_TOKEN_STORAGE_MODE=database_encrypted

# OpenAI — not used until plan P07
OPENAI_API_KEY=
OPENAI_MODEL=

# Risk defaults; deployed live values require manual review
CAPITAL_ALLOCATION_INR=2000
MAX_TRADE_NOTIONAL_INR=500
MAX_PLANNED_RISK_PER_TRADE_INR=10
MAX_DAILY_LOSS_INR=20
MAX_TRADES_PER_DAY=1
MAX_OPEN_POSITIONS=1
MIN_CASH_RESERVE_INR=1000
ENTRY_CUTOFF_IST=14:30
FORCE_FLAT_IST=15:10
