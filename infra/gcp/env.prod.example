APP_ENV=production
TRADING_MODE=OFF
LIVE_ARMED=false
APP_HOST=0.0.0.0
APP_PORT=8000

POSTGRES_DB=zerodha_ai_trader
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@postgres:5432/zerodha_ai_trader

REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

GCP_PROJECT_ID=
GCP_REGION=asia-south1
GCP_ZONE=
GCP_VM_NAME=
GCP_STATIC_IP=

SECRET_MANAGER_ENABLED=false
LOG_LEVEL=INFO

KITE_AUTH_ENABLED=false
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=
KITE_SESSION_ENCRYPTION_KEY=
OPERATOR_AUTH_TOKEN=

MARKET_DATA_ENABLED=false
INSTRUMENT_SYNC_ENABLED=false
KITE_WEBSOCKET_ENABLED=false
MARKET_DATA_WATCHLIST=NSE:NIFTYBEES,NSE:SBIN
MARKET_DATA_MODE=quote
MARKET_DATA_MAX_INSTRUMENTS=10
MARKET_DATA_STALE_AFTER_SECONDS=10
MARKET_DATA_CANDLE_INTERVAL=1minute
